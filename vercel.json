{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/api/index.js"
    }
  ],
  "redirects": [
    {
      "source": "/api/docs",
      "destination": "/api/docs/",
      "permanent": false
    }
  ]
}